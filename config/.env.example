# Database overrides
AUTOAPPLY_DB_HOST=localhost
AUTOAPPLY_DB_PORT=5432
AUTOAPPLY_DB_NAME=autoapply
AUTOAPPLY_DB_USER=autoapply
AUTOAPPLY_DB_PASSWORD=

# Logging override
AUTOAPPLY_LOG_LEVEL=INFO

# Optional CLI auth context
# Claude Code CLI and Codex CLI usually manage auth interactively,
# so API keys are only needed if your local CLI setup depends on them.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional platform credentials
# LinkedIn login is typically completed interactively on first run.
# LINKEDIN_EMAIL=
# LINKEDIN_PASSWORD=
